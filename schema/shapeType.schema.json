{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema/shapeType.schema.json",
  "title": "Shape Type Export (图形类型导出)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "data"
  ],
  "properties": {
    "type": {
      "const": "shapeType"
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/shapeType"
      }
    }
  },
  "definitions": {
    "shapeType": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "svg": {
          "type": "string"
        },
        "editableElements": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/primitive"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/parameter"
          }
        },
        "imported": {
          "type": "boolean"
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "label",
        "defaultValue"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "color",
            "text",
            "number",
            "checkbox"
          ]
        },
        "label": {
          "type": "string"
        },
        "defaultValue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        },
        "conditions": {
          "type": "array",
          "items": {}
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "primitive": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "line",
            "circle",
            "rect",
            "hexagon",
            "octagon",
            "bezier",
            "text"
          ]
        },
        "x1": {
          "type": "number"
        },
        "y1": {
          "type": "number"
        },
        "x2": {
          "type": "number"
        },
        "y2": {
          "type": "number"
        },
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number"
        },
        "radiusX": {
          "type": "number"
        },
        "radiusY": {
          "type": "number"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "rounded": {
          "type": "boolean"
        },
        "rx": {
          "type": "number"
        },
        "stroke": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
        },
        "strokeWidth": {
          "type": "number"
        },
        "roundCap": {
          "type": "boolean"
        },
        "rotation": {
          "type": "number"
        },
        "value": {
          "type": "string"
        },
        "fontSize": {
          "type": "number"
        },
        "fontFamily": {
          "type": "string"
        },
        "bold": {
          "type": "boolean"
        },
        "italic": {
          "type": "boolean"
        },
        "underline": {
          "type": "boolean"
        },
        "strikethrough": {
          "type": "boolean"
        },
        "fill": {
          "type": "string"
        },
        "paramBindings": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "paramId": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}